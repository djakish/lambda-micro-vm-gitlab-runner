{
  "name": "microvm-runner-example",
  "version": "0.1.0",
  "private": true,
  "description": "Quickstart CDK deployment: an AWS Lambda MicroVM GitLab runner host + GitLab OIDC",
  "bin": {
    "microvm-runner-example": "bin/app.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy --all",
    "destroy": "cdk destroy --all",
    "teardown": "cdk destroy --all --force && ./scripts/cleanup-microvms.sh"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "aws-cdk": "^2.170.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.4.2"
  },
  "packageManager": "pnpm@10.33.0"
}
